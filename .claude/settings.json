{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "NODE_ENV": "development"
  },
  "permissions": {
    "allow": [
      "Bash(npx expo install *)",
      "Bash(npx expo start *)",
      "Bash(npx expo doctor *)",
      "Bash(npx create-expo-app *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npx jest *)",
      "Bash(npx tsc *)",
      "Bash(npx eslint *)",
      "Bash(node *)",
      "Bash(python *)",
      "Bash(pip install *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(dir *)",
      "Bash(git *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "enabledPlugins": {
    "figma@figma": false
  }
}
