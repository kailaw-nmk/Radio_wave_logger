{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "NODE_ENV": "development"
  },
  "permissions": {
    "allow": [
      "Bash(npx expo *)",
      "Bash(npm *)",
      "Bash(npx jest *)",
      "Bash(npx tsc *)",
      "Bash(npx eslint *)",
      "Bash(node *)",
      "Bash(python *)",
      "Bash(pip install *)",
      "Bash(git *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(dir *)",
      "Bash(echo *)",
      "Bash(curl *)",
      "Bash(rm *)",
      "Bash(gh repo *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "enabledPlugins": {
    "figma@figma": false
  }
}
